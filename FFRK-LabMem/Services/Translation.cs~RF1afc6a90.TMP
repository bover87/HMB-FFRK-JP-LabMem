        // List of orb/crystal types in Japanese and their translations
        public static readonly Dictionary<String, String> OrbTypes = new Dictionary<String, String>()
        {
            { "炎", "Fire" },
            { "氷", "Ice" },
            { "雷", "Lightning" },
            { "水", "Water" },
            { "風", "Wind" },
